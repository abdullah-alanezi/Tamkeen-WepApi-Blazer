@page "/trainees"
@namespace WebClient.Pages.Trainees
@layout WebClient.Layout.MainLayout
@using Tamkeen.Core.Models.DTOs

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">

    <MudStack Spacing="4">

        <!-- ================= HEADER ================= -->
        <MudPaper Elevation="3" Class="pa-4"
                  Style="border-radius:12px;
                         background:linear-gradient(90deg,#594AE2 0%,#7467EF 100%);
                         color:white;">

            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween">

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" />
                    <MudText Typo="Typo.h4" Style="font-weight:700;">
                        قائمة المتدربين
                    </MudText>
                </MudStack>

                <!-- ✅ FIX: MudChip requires T -->
                <MudChip T="string"
                         Color="Color.Surface"
                         Variant="Variant.Filled"
                         Size="Size.Large">
                    إجمالي العدد: @_trainees.Count
                </MudChip>

            </MudStack>
        </MudPaper>

        <!-- ================= TABLE ================= -->
        <MudTable Items="@_trainees"
                  T="TraineeDto"
                  Hover="true"
                  Striped="true"
                  Elevation="4"
                  Filter="FilterFunc"
                  Class="rounded-lg">

            <!-- TOOLBAR -->
            <ToolBarContent>

                <MudText Typo="Typo.h6">المتدربون</MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddDialog"
                           Class="ms-4">
                    إضافة متدرب
                </MudButton>

                <MudSpacer />

                <MudTextField @bind-Value="_searchString"
                              Placeholder="بحث عن متدرب..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" />

            </ToolBarContent>

            <!-- HEADER -->
            <HeaderContent>
                <MudTh>الاسم الكامل</MudTh>
                <MudTh>البريد الإلكتروني</MudTh>
                <MudTh>التخصص</MudTh>
                <MudTh>الجامعة</MudTh>
                <MudTh Style="text-align:right">الإجراءات</MudTh>
            </HeaderContent>

            <!-- ROW -->
            <RowTemplate>

                <MudTd DataLabel="Name">
                    <MudStack Row="true" AlignItems="AlignItems.Center">

                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                            @context.FirstName?.FirstOrDefault()
                        </MudAvatar>

                        <MudStack Spacing="0">
                            <MudText Style="font-weight:600;">
                                @context.FullName
                            </MudText>

                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                ID: @context.Id
                            </MudText>
                        </MudStack>

                    </MudStack>
                </MudTd>

                <MudTd>
                    <MudLink Href="@($"mailto:{context.Email}")"
                             Color="Color.Info"
                             Underline="Underline.Hover">
                        @context.Email
                    </MudLink>
                </MudTd>

                <!-- ✅ FIX: MudChip -->
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Variant="Variant.Outlined">
                        @context.Major
                    </MudChip>
                </MudTd>

                <MudTd>@context.University</MudTd>

                <MudTd Style="text-align:right">

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />

                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Info"
                                   Size="Size.Small" />

                </MudTd>

            </RowTemplate>

            <!-- NO DATA -->
            <NoRecordsContent>
                <MudText Align="Align.Center" Class="pa-4">
                    لا توجد سجلات مطابقة للبحث
                </MudText>
            </NoRecordsContent>

            <!-- LOADING -->
            <LoadingContent>
                <MudText Align="Align.Center" Class="pa-4">
                    جاري التحميل...
                </MudText>
            </LoadingContent>

            <!-- PAGING -->
            <PagerContent>
                <MudTablePager RowsPerPageString="عدد الصفوف:" />
            </PagerContent>

        </MudTable>

        <!-- ================= ERROR ================= -->
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Variant="Variant.Filled"
                      Class="mt-4">
                @_errorMessage
            </MudAlert>
        }

    </MudStack>
</MudContainer>