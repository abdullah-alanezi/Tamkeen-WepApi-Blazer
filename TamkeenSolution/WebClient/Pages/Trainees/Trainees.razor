@page "/trainees"
@layout WebClient.Layout.MainLayout
@using Tamkeen.Core.Models.Trainee.Response

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudStack Spacing="4">

        <MudPaper Elevation="3" Class="pa-4"
                  Style="border-radius:12px;
                         background:linear-gradient(90deg,#594AE2 0%,#7467EF 100%);
                         color:white;">

            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween">

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" />
                    <MudText Typo="Typo.h4" Style="font-weight:700;">
                        قائمة المتدربين
                    </MudText>
                </MudStack>

                <MudChip T="string"
                         Color="Color.Surface"
                         Variant="Variant.Filled"
                         Size="Size.Large">
                    إجمالي العدد: @(_trainees?.Count ?? 0)
                </MudChip>

            </MudStack>
        </MudPaper>

        <MudTable Items="@_trainees"
                  T="TraineeResponse"
                  Hover="true"
                  Striped="true"
                  Elevation="4"
                  Filter="FilterFunc"
                  Class="rounded-lg">

            <ToolBarContent>
                <MudText Typo="Typo.h6">المتدربون</MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddDialog"
                           Class="ms-4">
                    إضافة متدرب
                </MudButton>

                <MudSpacer />

                <MudTextField @bind-Value="_searchString"
                              Placeholder="بحث..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Immediate="true" />
            </ToolBarContent>

            <HeaderContent>
                <MudTh>الاسم الكامل</MudTh>
                <MudTh>البريد الإلكتروني</MudTh>
                <MudTh>التخصص</MudTh>
                <MudTh>الجامعة</MudTh>
                <MudTh Style="text-align:right">الإجراءات</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="الاسم">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                            @GetInitials(context.FullName)
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Style="font-weight:600;">
                                @context.FullName
                            </MudText>

                        </MudStack>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="البريد">
                    <MudLink Href="@($"mailto:{context.Email}")"
                             Color="Color.Info"
                             Underline="Underline.Hover">
                        @context.Email
                    </MudLink>
                </MudTd>

                <MudTd DataLabel="التخصص">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Variant="Variant.Outlined">
                        @context.Major
                    </MudChip>
                </MudTd>

                <MudTd DataLabel="الجامعة">@context.University</MudTd>

                <MudTd Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText Align="Align.Center" Class="pa-4">
                    لا توجد بيانات لعرضها حالياً
                </MudText>
            </NoRecordsContent>

            <LoadingContent>
                <MudText Align="Align.Center" Class="pa-4">
                    جاري جلب البيانات من الخادم...
                </MudText>
            </LoadingContent>

            <PagerContent>
                <MudTablePager RowsPerPageString="عدد الصفوف في الصفحة:" />
            </PagerContent>
        </MudTable>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Variant="Variant.Filled"
                      Elevation="2"
                      OnClose="@(() => _errorMessage = null)"
                      Class="mt-2">
                @_errorMessage
            </MudAlert>
        }

    </MudStack>
</MudContainer>