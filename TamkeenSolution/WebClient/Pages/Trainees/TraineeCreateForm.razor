
@using Tamkeen.Core.Models.Trainee.Request

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة متدرب جديد</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form">

            <MudGrid Spacing="2">

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FirstName"
                                  Label="الاسم الأول"
                                  Required="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LastName"
                                  Label="الاسم الأخير"
                                  Required="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Email"
                                  Label="البريد الإلكتروني"
                                  InputType="InputType.Email"
                                  Required="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.PhoneNumber"
                                  Label="رقم الجوال" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.University"
                                  Label="الجامعة" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Major"
                                  Label="التخصص" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.UserSSN"
                                  Label="رقم الهوية (SSN)"
                                  Required="true" />
                </MudItem>

            </MudGrid>

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Color="Color.Success" OnClick="Submit">إضافة</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private TraineeCreateDto Model { get; set; } = new();
    private MudForm _form = default!;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();

        if (_form.IsValid)
            MudDialog.Close(DialogResult.Ok(Model));
    }
}