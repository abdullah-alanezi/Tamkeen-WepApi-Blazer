@using Tamkeen.Core.Models.Trainee.Request
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة متدرب جديد</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FirstName" Label="الاسم الأول" Required="true" RequiredError="الاسم الأول مطلوب" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LastName" Label="الاسم الأخير" Required="true" RequiredError="الاسم الأخير مطلوب" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Email" Label="البريد الإلكتروني" InputType="InputType.Email" Required="true" RequiredError="البريد الإلكتروني مطلوب" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.PhoneNumber" Label="رقم الجوال" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.University" Label="الجامعة" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Major" Label="التخصص" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.UserSSN" Label="رقم الهوية (SSN)" Required="true" RequiredError="رقم الهوية مطلوب" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Submit">إضافة</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public TraineeCreateDto Model { get; set; } = new();
    private MudForm _form = default!;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid)
            MudDialog.Close(DialogResult.Ok(Model));
    }
}