@namespace WebClient.Pages.Trainees
@using Tamkeen.Core.Models.DTOs

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تعديل بيانات المتدرب</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FirstName"
                                  Label="الاسم الأول"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LastName"
                                  Label="الاسم الأخير"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Email"
                                  Label="البريد الإلكتروني"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.PhoneNumber"
                                  Label="رقم الجوال"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.University"
                                  Label="الجامعة"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Major"
                                  Label="التخصص"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudContainer>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default" Class="px-6">إلغاء</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="px-10">حفظ التغييرات</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter]
    public TraineeDto Model { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        // هنا يمكنك إضافة منطق التحقق (Validation) قبل الإغلاق إذا أردت
        MudDialog.Close(DialogResult.Ok(Model));
    }
}