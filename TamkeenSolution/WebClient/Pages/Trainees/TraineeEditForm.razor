
@using Tamkeen.Core.Models.Trainee.Request

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تعديل بيانات المتدرب</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: auto">

            <MudGrid Spacing="2">

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.FirstName" Label="الاسم الأول" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LastName" Label="الاسم الأخير" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Email" Label="البريد الإلكتروني" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.PhoneNumber" Label="رقم الجوال" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.University" Label="الجامعة" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Major" Label="التخصص" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.UserSSN" Label="رقم الهوية" />
                </MudItem>

            </MudGrid>

        </MudContainer>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">حفظ</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public TraineeCreateDto Model { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(Model));
    }
}